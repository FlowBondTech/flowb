{
  "name": "danz-backend",
  "main": "dist/server.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nodemon src/server.ts",
    "dev:tsx": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "clean": "rm -rf node_modules dist",
    "reinstall": "pnpm run clean && pnpm install",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.0.17",
    "nodemon": "^3.1.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.17",
    "@types/jsonwebtoken": "^9.0.9"
  },
  "dependencies": {
    "@apollo/server": "4",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/s3-presigned-post": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.888.0",
    "@graphql-tools/merge": "^9.1.1",
    "@graphql-tools/schema": "^10.0.25",
    "@supabase/supabase-js": "^2.57.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "graphql": "^16.11.0",
    "graphql-scalars": "^1.24.2",
    "graphql-tag": "^2.12.6",
    "resend": "^6.7.0",
    "stripe": "^18.5.0",
    "jsonwebtoken": "^9.0.2"
  }
}
