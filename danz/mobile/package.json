{
  "name": "danz-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "web": "App.web.tsx",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android --device",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "emulator": "./start-emulator.sh",
    "emulator:list": "~/Library/Android/sdk/emulator/emulator -list-avds",
    "android:emu": "./start-emulator.sh && sleep 10 && expo run:android",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build:android:local": "eas build --platform android --local",
    "build:android:apk": "cd android && ./gradlew assembleRelease && cd ..",
    "build:android:apk:debug": "cd android && ./gradlew assembleDebug && cd ..",
    "build:android:bundle": "cd android && ./gradlew bundleRelease && cd ..",
    "build:android:clean": "cd android && ./gradlew clean && cd ..",
    "build:all": "eas build --platform all",
    "prebuild": "expo prebuild",
    "prebuild:android": "expo prebuild --platform android",
    "prebuild:clean": "expo prebuild --clear",
    "test:referral": "node test-referral-system.js",
    "codegen": "graphql-codegen --config codegen.ts",
    "ios:clean": "expo start --ios --clear",
    "simulator:start": "./scripts/simulator.sh start",
    "simulator:stop": "./scripts/simulator.sh stop",
    "simulator:clean": "./scripts/simulator.sh clean",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
